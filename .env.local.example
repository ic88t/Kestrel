# --- Shopify Storefront (public, sent from server) ---
# Get from: Shopify Admin → Apps → Headless → Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=

# --- Shopify Admin (private, used ONLY by scripts/seed-products.ts) ---
# Get from: Shopify Admin → Apps → Headless → Admin API access token
# Do NOT expose in client code. Only the seed script reads this.
SHOPIFY_ADMIN_TOKEN=

# --- Webhook secret (you make this up) ---
# Used by /api/revalidate to authenticate Shopify webhook posts.
SHOPIFY_REVALIDATION_SECRET=change-me-to-a-random-string

# Behaviour:
#  - If SHOPIFY_STORE_DOMAIN and SHOPIFY_STOREFRONT_TOKEN are BOTH set,
#    the site uses live Shopify data + a real Shopify cart + Shop Pay checkout.
#  - Otherwise, the site runs on mock data with a cookie-backed mock cart
#    (checkout is disabled with an explanatory page).
