<section class="kestrel-page" style="padding-top:80px;">
  <div class="page-width">
    <h1 class="kestrel-page__title">My Account</h1>
    <div style="display:grid;grid-template-columns:1fr 2fr;gap:48px;margin-top:32px;">
      <div>
        <p style="font-size:12px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:16px;">Account Details</p>
        <p style="font-size:14px;margin-bottom:4px;">{{ customer.first_name }} {{ customer.last_name }}</p>
        <p style="font-size:13px;color:var(--color-text-secondary);margin-bottom:16px;">{{ customer.email }}</p>
        <a href="/account/addresses" style="font-size:12px;text-decoration:underline;text-underline-offset:2px;">Manage Addresses</a>
      </div>
      <div>
        <p style="font-size:12px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:16px;">Order History</p>
        {%- if customer.orders.size > 0 -%}
          <div style="display:flex;flex-direction:column;gap:16px;">
            {%- for order in customer.orders -%}
              <div style="padding:20px;border:1px solid var(--color-border);">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                  <span style="font-size:13px;font-weight:500;">{{ order.name }}</span>
                  <span style="font-size:12px;color:var(--color-text-muted);">{{ order.created_at | date: "%B %d, %Y" }}</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <span style="font-size:12px;color:var(--color-text-secondary);">{{ order.line_items.size }} item{% if order.line_items.size > 1 %}s{% endif %}</span>
                  <span style="font-size:13px;font-weight:500;">{{ order.total_price | money }}</span>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          <p style="font-size:13px;color:var(--color-text-secondary);">You haven't placed any orders yet.</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
