<section class="kestrel-page" style="padding-top:80px;">
  <div class="page-width">
    <a href="/account" style="font-size:12px;text-decoration:underline;text-underline-offset:2px;margin-bottom:16px;display:inline-block;">← Back to Account</a>
    <h1 class="kestrel-page__title">Order {{ order.name }}</h1>
    <p style="font-size:13px;color:var(--color-text-secondary);margin-bottom:32px;">Placed on {{ order.created_at | date: "%B %d, %Y" }}</p>

    <div style="border:1px solid var(--color-border);margin-bottom:32px;">
      {%- for line_item in order.line_items -%}
        <div style="display:flex;gap:16px;padding:20px;border-bottom:1px solid var(--color-border);">
          <div style="width:80px;height:80px;background:var(--color-bg-card);flex-shrink:0;">
            {%- if line_item.image -%}
              <img src="{{ line_item.image | image_url: width: 200 }}" alt="" width="200" height="200" loading="lazy" style="width:100%;height:100%;object-fit:contain;">
            {%- endif -%}
          </div>
          <div>
            <p style="font-size:13px;font-weight:500;text-transform:uppercase;">{{ line_item.title }}</p>
            <p style="font-size:12px;color:var(--color-text-muted);">{{ line_item.quantity }} × {{ line_item.price | money }}</p>
          </div>
        </div>
      {%- endfor -%}
      <div style="padding:20px;display:flex;justify-content:space-between;">
        <span style="font-size:13px;font-weight:500;">Total</span>
        <span style="font-size:13px;font-weight:600;">{{ order.total_price | money }}</span>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;">
      <div>
        <p style="font-size:12px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:12px;">Shipping Address</p>
        <p style="font-size:13px;line-height:1.7;color:var(--color-text-secondary);">{{ order.shipping_address | format_address }}</p>
      </div>
      <div>
        <p style="font-size:12px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:12px;">Status</p>
        <p style="font-size:13px;color:var(--color-text-secondary);">{{ order.fulfillment_status_label }}</p>
      </div>
    </div>
  </div>
</section>
