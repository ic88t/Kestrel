<section class="kestrel-account" style="padding-top:80px;">
  <div class="page-width">
    <div class="kestrel-account__inner">
      <h1 class="kestrel-account__title">Reset Password</h1>
      <p class="kestrel-account__subtitle">Enter a new password for your account.</p>
      {%- form 'reset_customer_password' -%}
        {%- if form.errors -%}
          <p style="color:#c00;font-size:13px;margin-bottom:16px;">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="kestrel-account__field">
          <label for="CustomerPassword">New Password</label>
          <input type="password" id="CustomerPassword" name="customer[password]" placeholder="••••••••" required>
        </div>
        <div class="kestrel-account__field">
          <label for="CustomerPasswordConfirmation">Confirm Password</label>
          <input type="password" id="CustomerPasswordConfirmation" name="customer[password_confirmation]" placeholder="••••••••" required>
        </div>
        <button type="submit" class="kestrel-account__submit">Reset Password</button>
      {%- endform -%}
    </div>
  </div>
</section>
