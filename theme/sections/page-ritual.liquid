<section class="kestrel-page" style="padding-top:80px;">
  <div class="page-width">
    <p style="font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:12px;">Ritual Finder</p>
    <h1 class="kestrel-page__title">Build your ritual.</h1>

    <div style="max-width:600px;margin-top:48px;">
      <div style="margin-bottom:40px;">
        <p style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:16px;">Step 1</p>
        <p style="font-size:16px;font-weight:500;margin-bottom:16px;">What's your main concern?</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">Thinning</button>
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">Receding hairline</button>
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">Both</button>
        </div>
      </div>

      <div style="margin-bottom:40px;">
        <p style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:16px;">Step 2</p>
        <p style="font-size:16px;font-weight:500;margin-bottom:16px;">How long have you noticed it?</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">Less than 6 months</button>
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">6-12 months</button>
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">Over a year</button>
        </div>
      </div>

      <div style="margin-bottom:40px;">
        <p style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:16px;">Step 3</p>
        <p style="font-size:16px;font-weight:500;margin-bottom:16px;">What's your current routine?</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">Nothing specific</button>
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">Basic shampoo</button>
          <button style="text-align:left;padding:16px;border:1px solid var(--color-border);font-size:13px;background:var(--color-bg);cursor:pointer;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'" onmouseout="this.style.borderColor='var(--color-border)'">Some treatments</button>
        </div>
      </div>

      <div style="padding:32px;border:1px solid var(--color-border);">
        <p style="font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:12px;">Your recommendation</p>
        <h3 style="font-family:var(--font-heading);font-size:24px;font-weight:500;text-transform:uppercase;margin-bottom:12px;">The Complete Ritual Set</h3>
        <p style="font-size:13px;line-height:1.7;color:var(--color-text-secondary);margin-bottom:20px;">Based on your answers, we recommend starting with all three formulas for maximum density support.</p>
        <a href="/collections/all" style="display:inline-block;background:var(--color-ink);color:var(--color-white);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;font-weight:500;padding:14px 28px;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Shop the Set</a>
      </div>
    </div>
  </div>
</section>
