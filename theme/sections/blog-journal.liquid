<section class="kestrel-page" style="padding-top:80px;">
  <div class="page-width">
    <p style="font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:12px;">The Journal</p>
    <h1 class="kestrel-page__title">Reading on density.</h1>
    <p class="kestrel-page__body" style="margin-bottom:48px;">Long-form essays on hair, scalp, and what discipline looks like after thirty-five.</p>

    <div style="display:grid;grid-template-columns:1fr;gap:32px;margin-bottom:48px;">
      <a href="#" style="display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center;">
        <div style="aspect-ratio:16/10;background:var(--color-bg-card);overflow:hidden;">
          <img src="{{ 'hero-product.jpg' | asset_url }}" alt="" style="width:100%;height:100%;object-fit:cover;filter:grayscale(100%);">
        </div>
        <div>
          <p style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:12px;">Science · 2026.04 · 8 min</p>
          <h2 style="font-family:var(--font-heading);font-size:22px;font-weight:500;text-transform:uppercase;line-height:1.2;margin-bottom:12px;">The science of density.</h2>
          <p style="font-size:13px;line-height:1.7;color:var(--color-text-secondary);">Why the conversation around hair loss has been wrong for decades — and what the follicle actually needs.</p>
        </div>
      </a>
    </div>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:32px;">
      {%- for i in (1..2) -%}
        <a href="#">
          <div style="aspect-ratio:16/10;background:var(--color-bg-card);overflow:hidden;margin-bottom:16px;">
            <img src="{{ 'hero-product.jpg' | asset_url }}" alt="" style="width:100%;height:100%;object-fit:cover;filter:grayscale(100%);">
          </div>
          <p style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:8px;">Philosophy · 2026.03 · 4 min</p>
          <h3 style="font-family:var(--font-heading);font-size:16px;font-weight:500;text-transform:uppercase;line-height:1.3;margin-bottom:8px;">Rituals, not routines.</h3>
          <p style="font-size:13px;line-height:1.6;color:var(--color-text-secondary);">On the difference between performing a habit and inhabiting one.</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
