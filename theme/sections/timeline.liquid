<section class="kestrel-timeline">
  <div class="page-width kestrel-timeline__grid">
    <div>
      <h2 class="kestrel-timeline__title animate animate--fade-up">Changes can start sooner than you'd think</h2>
      <div class="kestrel-timeline__items">
        <div class="kestrel-timeline__item animate animate--fade-up animate-delay-1">
          <span class="kestrel-timeline__day">Day 30</span>
          <div class="kestrel-timeline__content">
            <h4>Hair may feel stronger and fuller.</h4>
            <p>Many customers report improvements in quality within weeks.</p>
          </div>
        </div>
        <div class="kestrel-timeline__item animate animate--fade-up animate-delay-2">
          <span class="kestrel-timeline__day">Day 45</span>
          <div class="kestrel-timeline__content">
            <h4>Noticeable reduction in shedding.</h4>
            <p>Up to 80% had less hair shedding after 45 days.</p>
          </div>
        </div>
        <div class="kestrel-timeline__item animate animate--fade-up animate-delay-3">
          <span class="kestrel-timeline__day">Day 90</span>
          <div class="kestrel-timeline__content">
            <h4>Increased hair density may be noticeable.</h4>
            <p>Clinically tested increase in density for most users.</p>
          </div>
        </div>
        <div class="kestrel-timeline__item animate animate--fade-up animate-delay-4">
          <span class="kestrel-timeline__day">Day 150</span>
          <div class="kestrel-timeline__content">
            <h4>Baby hairs sprouting.</h4>
            <p>73% had increased hair density after 150 days.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="kestrel-timeline__image animate animate--slide-right animate-delay-2">
      <img src="{{ 'hero-lifestyle.jpg' | asset_url }}" alt="" width="600" height="450">
    </div>
  </div>
</section>
