<section class="kestrel-related">
  <div class="page-width">
    <div class="kestrel-related__tabs">
      <button class="kestrel-related__tab is-active">Best Sellers</button>
      <button class="kestrel-related__tab">Skin Care</button>
      <button class="kestrel-related__tab">Hair Loss</button>
      <button class="kestrel-related__tab">Hair Care</button>
    </div>
    <div class="kestrel-related__grid">
      {%- for i in (1..4) -%}
        <div class="kestrel-related__card">
          <div class="kestrel-related__image">
            <div style="width:70%;height:70%;background:linear-gradient(135deg,#ddd,#bbb);border-radius:4px;"></div>
          </div>
          <p class="kestrel-related__name">ND1 | Natural Deodorant</p>
          <p class="kestrel-related__price">$38.00</p>
          <button class="kestrel-related__atc">Add to Cart</button>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
