<header class="kestrel-header" data-header>
  <div class="page-width kestrel-header__inner">
    <nav class="kestrel-header__nav">
      <a href="/collections/all">Shop</a>
      <a href="/blogs/journal">Science</a>
      <a href="/pages/ritual">Ritual</a>
      <a href="/pages/contact">Support</a>
    </nav>

    <button class="kestrel-header__menu-btn" data-mobile-menu-trigger aria-label="Menu">
      <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>

    <a href="/" class="kestrel-header__logo" style="font-size:22px;font-weight:700;letter-spacing:0.2em;">KESTREL</a>

    <div class="kestrel-header__actions">
      <a href="/pages/ritual" class="kestrel-header__quiz">Hair Quiz</a>
      <a href="/search" class="kestrel-header__icon-btn" aria-label="Search">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
      </a>
      <a href="{% if customer %}/account{% else %}/account/login{% endif %}" class="kestrel-header__icon-btn" aria-label="Account">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
      </a>
      <a href="/cart" class="kestrel-header__icon-btn relative" aria-label="Cart">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="kestrel-header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

<div class="kestrel-mobile-menu" data-mobile-menu>
  <div class="kestrel-mobile-menu__panel">
    <button class="kestrel-mobile-menu__close" data-mobile-menu-close aria-label="Close">
      <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
    <nav class="kestrel-mobile-menu__nav">
      <a href="/collections/all">Shop</a>
      <a href="/blogs/journal">Science</a>
      <a href="/pages/ritual">Ritual</a>
      <a href="/pages/about">About</a>
      <a href="/pages/contact">Support</a>
    </nav>
  </div>
</div>
