<section class="kestrel-hero">
  <div class="kestrel-hero__media">
    {%- if section.settings.video_url != blank -%}
      <video autoplay muted loop playsinline poster="{{ section.settings.image | image_url: width: 2000 }}">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}"
           alt="{{ section.settings.image.alt | escape }}"
           width="2000" height="1333"
           loading="eager">
    {%- else -%}
      <img src="{{ 'hero-dark.jpg' | asset_url }}" alt="" width="2000" height="1333" loading="eager">
    {%- endif -%}
  </div>
  <div class="kestrel-hero__overlay"></div>
  <div class="kestrel-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="kestrel-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="kestrel-hero__title">{{ section.settings.title | default: "Hair growth the natural way" }}</h1>
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="kestrel-hero__btn">
        {{ section.settings.button_label }}
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    {%- endif -%}
  </div>
</section>

{%- if section.settings.show_cat_tabs -%}
<div class="kestrel-cat-tabs">
  <div class="page-width kestrel-cat-tabs__inner">
    <a href="/collections/all" class="is-active">Best Sellers</a>
    <a href="/collections/hair-loss">Hair Loss</a>
    <a href="/collections/skincare">Skin Care</a>
    <a href="/collections/systems">Systems</a>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "url", "id": "video_url", "label": "Video URL (MP4)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Now Available" },
    { "type": "text", "id": "title", "label": "Title", "default": "FS1 — Crushed Diamond Face Scrub" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "show_cat_tabs", "label": "Show category tabs", "default": true }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
