<section class="kestrel-results-section">
  <div class="page-width">
    <h2 class="kestrel-results-section__title">See How Men Like You Transformed Their Hair</h2>

    <div class="kestrel-results-section__grid">
      <div class="kestrel-result-card">
        <div class="kestrel-result-card__images">
          <div class="kestrel-result-card__img">
            <img src="{{ 'bottle-1.jpg' | asset_url }}" alt="Before" width="300" height="300" loading="lazy">
            <span class="kestrel-result-card__label">Before</span>
          </div>
          <div class="kestrel-result-card__img">
            <img src="{{ 'serum-1.jpg' | asset_url }}" alt="After" width="300" height="300" loading="lazy">
            <span class="kestrel-result-card__label">After</span>
          </div>
        </div>
        <div class="kestrel-result-card__meta">
          <span class="kestrel-result-card__badge">Crown Results</span>
          <p class="kestrel-result-card__quote">"Finally found something that actually works. My crown area is filling in and I'm not seeing my scalp anymore."</p>
          <p class="kestrel-result-card__author">Mark T. — <span class="kestrel-result-card__verified">Verified Buyer</span></p>
        </div>
      </div>

      <div class="kestrel-result-card">
        <div class="kestrel-result-card__images">
          <div class="kestrel-result-card__img">
            <img src="{{ 'bottle-2.jpg' | asset_url }}" alt="Before" width="300" height="300" loading="lazy">
            <span class="kestrel-result-card__label">Before</span>
          </div>
          <div class="kestrel-result-card__img">
            <img src="{{ 'bottle-3.jpg' | asset_url }}" alt="After" width="300" height="300" loading="lazy">
            <span class="kestrel-result-card__label">After</span>
          </div>
        </div>
        <div class="kestrel-result-card__meta">
          <span class="kestrel-result-card__badge">Hairline Transformation</span>
          <p class="kestrel-result-card__quote">"My hairline was my biggest concern. Now I style with confidence again."</p>
          <p class="kestrel-result-card__author">James R. — <span class="kestrel-result-card__verified">Verified Buyer</span></p>
        </div>
      </div>

      <div class="kestrel-result-card">
        <div class="kestrel-result-card__images">
          <div class="kestrel-result-card__img">
            <img src="{{ 'oil-1.jpg' | asset_url }}" alt="Before" width="300" height="300" loading="lazy">
            <span class="kestrel-result-card__label">Before</span>
          </div>
          <div class="kestrel-result-card__img">
            <img src="{{ 'serum-2.jpg' | asset_url }}" alt="After" width="300" height="300" loading="lazy">
            <span class="kestrel-result-card__label">After</span>
          </div>
        </div>
        <div class="kestrel-result-card__meta">
          <span class="kestrel-result-card__badge">Overall Thickness</span>
          <p class="kestrel-result-card__quote">"From thin and lifeless to thick and full. My wife can't stop running her fingers through my hair."</p>
          <p class="kestrel-result-card__author">Robert M. — <span class="kestrel-result-card__verified">Verified Buyer</span></p>
        </div>
      </div>

      <div class="kestrel-result-card">
        <div class="kestrel-result-card__images">
          <div class="kestrel-result-card__img">
            <img src="{{ 'hero-dark.jpg' | asset_url }}" alt="Before" width="300" height="300" loading="lazy">
            <span class="kestrel-result-card__label">Before</span>
          </div>
          <div class="kestrel-result-card__img">
            <img src="{{ 'hero-lifestyle.jpg' | asset_url }}" alt="After" width="300" height="300" loading="lazy">
            <span class="kestrel-result-card__label">After</span>
          </div>
        </div>
        <div class="kestrel-result-card__meta">
          <span class="kestrel-result-card__badge">Styling Success</span>
          <p class="kestrel-result-card__quote">"Used to hate seeing photos of myself. Now I actually like how my hair looks styled."</p>
          <p class="kestrel-result-card__author">William K. — <span class="kestrel-result-card__verified">Verified Buyer</span></p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
