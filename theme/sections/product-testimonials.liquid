<section class="kestrel-testimonials">
  <div class="page-width">
    <h2 class="kestrel-testimonials__title">50,000 Happy Customers and Counting...</h2>

    <div class="kestrel-testimonials__grid">
      <div class="kestrel-testimonial-card">
        <div class="kestrel-testimonial-card__avatar">
          <img src="{{ 'hero-lifestyle.jpg' | asset_url }}" alt="Ryan M." width="80" height="80" loading="lazy">
        </div>
        <div class="kestrel-testimonial-card__stars">
          {%- for i in (1..5) -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- endfor -%}
        </div>
        <p class="kestrel-testimonial-card__headline">Patchy to Full</p>
        <p class="kestrel-testimonial-card__quote">"Started with barely any growth in some areas. This oil changed everything. New growth filling in the patches, and my existing beard feels stronger. Finally growing a real beard!"</p>
        <p class="kestrel-testimonial-card__author">Ryan M. - <span class="kestrel-testimonial-card__verified">Verified Buyer</span></p>
        <p class="kestrel-testimonial-card__meta">Age: 28</p>
        <p class="kestrel-testimonial-card__meta">6 weeks using Beard Growth Oil</p>
      </div>

      <div class="kestrel-testimonial-card">
