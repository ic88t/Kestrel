<div class="cart-drawer" data-cart-drawer>
  <div class="cart-drawer__overlay" data-cart-drawer-overlay></div>
  <div class="cart-drawer__panel">
    <div class="cart-drawer__loader" data-cart-drawer-loader></div>

    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">My Cart</h2>
      <button class="cart-drawer__close" data-cart-drawer-close aria-label="Close cart">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="cart-drawer__shipping-bar" data-cart-drawer-shipping>
      <div class="cart-drawer__shipping-text" data-shipping-text>Add <strong>$99.00</strong> more for free shipping!</div>
      <div class="cart-drawer__shipping-track">
        <div class="cart-drawer__shipping-fill" data-shipping-fill style="width:0%"></div>
      </div>
    </div>

    <div class="cart-drawer__body" data-cart-drawer-body>
      <!-- Cart items injected via JS -->
    </div>

    <div class="cart-drawer__footer" data-cart-drawer-footer>
      <div class="cart-drawer__summary-row">
        <span>Subtotal</span>
        <span data-cart-subtotal>$0.00</span>
      </div>
      <div class="cart-drawer__summary-row" data-cart-discount-row style="display:none;">
        <span>Discount</span>
        <span data-cart-discount>-$0.00</span>
      </div>
      <div class="cart-drawer__summary-row cart-drawer__summary-row--total">
        <span>Total</span>
        <span data-cart-total>$0.00</span>
      </div>
      <a href="/checkout" class="cart-drawer__checkout-btn">Secure Checkout</a>
      <div class="cart-drawer__trust">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
        </svg>
        150-Day Money-Back Guarantee
      </div>
      <div class="cart-drawer__trust-cards">
        <svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#1A1F71"/><text x="24" y="20" text-anchor="middle" fill="white" font-size="10" font-weight="700" font-family="Arial, sans-serif">VISA</text></svg>
        <svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#EB001B"/><circle cx="18" cy="15" r="8" fill="#EB001B"/><circle cx="30" cy="15" r="8" fill="#F79E1B"/><path d="M24 9a8 8 0 0 1 0 12 8 8 0 0 1 0-12z" fill="#FF5F00"/></svg>
        <svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#000"/><text x="24" y="20" text-anchor="middle" fill="white" font-size="9" font-weight="700" font-family="Arial, sans-serif">AMEX</text></svg>
        <svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#0085D0"/><text x="24" y="20" text-anchor="middle" fill="white" font-size="10" font-weight="700" font-family="Arial, sans-serif">Pay</text></svg>
      </div>
    </div>
  </div>
</div>
