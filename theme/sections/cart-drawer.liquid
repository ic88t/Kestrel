<div class="cart-drawer" data-cart-drawer>
  <div class="cart-drawer__overlay" data-cart-drawer-close></div>
  <div class="cart-drawer__panel">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title" data-cart-drawer-title>My Cart (0)</h2>
      <button class="cart-drawer__close" data-cart-drawer-close aria-label="Close cart">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="cart-drawer__shipping" data-cart-drawer-shipping>
      <div class="cart-drawer__shipping-bar">
        <div class="cart-drawer__shipping-fill" data-cart-shipping-fill></div>
      </div>
      <p class="cart-drawer__shipping-text" data-cart-shipping-text>Add $50 more for free shipping!</p>
    </div>

    <div class="cart-drawer__items" data-cart-drawer-items>
      <!-- Items injected via JS -->
    </div>

    <div class="cart-drawer__empty" data-cart-drawer-empty>
      <p>Your cart is empty</p>
      <a href="/collections/all" class="cart-drawer__continue">Continue Shopping</a>
    </div>

    <div class="cart-drawer__footer" data-cart-drawer-footer>
      <div class="cart-drawer__row">
        <span>Subtotal</span>
        <span data-cart-subtotal>$0.00</span>
      </div>
      <div class="cart-drawer__row cart-drawer__row--discount" data-cart-discount-row style="display:none;">
        <span>Discount</span>
        <span data-cart-discount>-$0.00</span>
      </div>
      <div class="cart-drawer__row cart-drawer__row--total">
        <span>Total</span>
        <span data-cart-total>$0.00</span>
      </div>
      <a href="/checkout" class="cart-drawer__checkout">Secure Checkout</a>
      <div class="cart-drawer__trust">
        <span class="cart-drawer__guarantee">🔒 150-Day Satisfaction Guarantee</span>
        <div class="cart-drawer__payment-icons">
          <svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#1A1F71"/><text x="24" y="20" text-anchor="middle" fill="white" font-size="10" font-weight="700" font-family="Arial">VISA</text></svg>
          <svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#EB001B"/><circle cx="18" cy="15" r="8" fill="#EB001B"/><circle cx="30" cy="15" r="8" fill="#F79E1B"/><path d="M24 9a8 8 0 0 1 0 12 8 8 0 0 1 0-12z" fill="#FF5F00"/></svg>
          <svg width="32" height="20" viewBox="0 0 48 30" fill="none"><rect width="48" height="30" rx="4" fill="#000"/><text x="24" y="20" text-anchor="middle" fill="white" font-size="9" font-weight="700" font-family="Arial">AMEX</text></svg>
        </div>
      </div>
    </div>
  </div>
</div>
